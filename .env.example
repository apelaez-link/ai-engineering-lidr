# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno.
# Copia este archivo a .env y rellena tus valores reales:
#   cp .env.example .env
# El .env real NUNCA se sube al repo (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Proveedores y fallback ───────────────────────────────────
# Proveedor preferido (compatibilidad con la sesión 02).
LLM_PROVIDER=openai

# Orden de fallback: el wrapper intenta el primero; si falla, rota al siguiente.
# Solo se usan los proveedores que tengan API key rellenada más abajo.
PROVIDER_FALLBACK_ORDER=openai,anthropic

# Claves de API (rellena al menos una; las dos para probar el fallback de verdad)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Modelos económicos recomendados para el ejercicio
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5

# Parámetros de generación
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1500

# ── Cacheo (sesión 03) ───────────────────────────────────────
CACHE_ENABLED=true
# "memory" (por defecto, sin infra) o "redis"
CACHE_BACKEND=memory
CACHE_TTL_SECONDS=86400
# Solo se usa si CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# ── Observabilidad / logging (sesión 03) ─────────────────────
# "development" -> consola legible | "production" -> JSON
ENV=development
LOG_LEVEL=INFO
